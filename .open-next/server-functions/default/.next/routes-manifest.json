    },
    {
      "page": "/sign-in",
      "regex": "^/sign\\-in(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sign\\-in(?:/)?$"
    },
    {
      "page": "/sitemap.xml",
      "regex": "^/sitemap\\.xml(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sitemap\\.xml(?:/)?$"
    },
    {
      "page": "/templates",
      "regex": "^/templates(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/templates(?:/)?$"
    },
    {
      "page": "/terms",
      "regex": "^/terms(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/terms(?:/)?$"
    },
    {
      "page": "/themes",
      "regex": "^/themes(?:/)?$",
