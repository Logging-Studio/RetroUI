      "namedRegex": "^/demo/components(?:/)?$"
    },
    {
      "page": "/docs/components",
      "regex": "^/docs/components(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/docs/components(?:/)?$"
    },
    {
      "page": "/downloads/figma",
      "regex": "^/downloads/figma(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/downloads/figma(?:/)?$"
    },
    {
      "page": "/favicon.ico",
      "regex": "^/favicon\\.ico(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/favicon\\.ico(?:/)?$"
    },
    {
      "page": "/figma",
      "regex": "^/figma(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/figma(?:/)?$"
    },
    {
      "page": "/organization",
